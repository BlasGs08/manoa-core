# Terraform
.terraform/
*.tfstate
*.tfstate.*

# .tfvars (contain sensitive data)
*.tfvars
!environments/**/.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local .terraform directories
**/.terraform/

# .terraform.lock.hcl (pinned versions)
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Exclude files that could contain credentials
*.backup
*.bak

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node (if running locally)
node_modules/

# Environment files (we use .gitignore to exclude .env files)
.env
.env.*
!.env.example